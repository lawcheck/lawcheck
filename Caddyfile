# Caddy автоматически выпускает и продлевает TLS-сертификат Let's Encrypt
# для доменов ниже. Требуется, чтобы A-записи lawchek.ru и www.lawchek.ru
# указывали на этот сервер и были открыты порты 80/443.

lawchek.ru {
	encode zstd gzip

	# Access-лог для серверной аналитики (GoAccess читает его из общего тома).
	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 5
		}
	}

	# Отчёт GoAccess — под basic auth (логин maxim).
	handle_path /stats* {
		basic_auth {
			maxim $2a$14$O0CaflJ9VbOnzyrqTifz6.W1e1r6bCQ9YYJE.CXVHfUaNrqzeN6uW
		}
		root * /srv/goaccess
		file_server
	}

	# Входящие (заявки + лиды) — тот же basic auth (логин maxim), но рендерит API.
	handle /inbox* {
		basic_auth {
			maxim $2a$14$O0CaflJ9VbOnzyrqTifz6.W1e1r6bCQ9YYJE.CXVHfUaNrqzeN6uW
		}
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy api:8000
	}
}

www.lawchek.ru {
	redir https://lawchek.ru{uri} permanent
}
