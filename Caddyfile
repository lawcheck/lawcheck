# Caddy автоматически выпускает и продлевает TLS-сертификат Let's Encrypt
# для доменов ниже. Требуется, чтобы A-записи lawchek.ru и www.lawchek.ru
# указывали на этот сервер и были открыты порты 80/443.

lawchek.ru {
	reverse_proxy api:8000
	encode zstd gzip
}

www.lawchek.ru {
	redir https://lawchek.ru{uri} permanent
}
